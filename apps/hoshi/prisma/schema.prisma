generator db {
  provider = "go run github.com/steebchen/prisma-client-go"
  binaryTargets = ["darwin-arm64", "linux-static-x64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Settings {
  id                  Int      @id @default(autoincrement())
  guildId             String   @unique
  botUpdatesChannelId String?

  treshold          Int      @default(3)
  self              Boolean  @default(false)
  ignoredChannelIds String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Starboards {
  id Int @id @default(autoincrement())

  guildId         String
  sourceEmoji     String  @default("⭐")
  sourceChannelId String?
  targetChannelId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Log {
  id                Int    @id @default(autoincrement())
  guildId           String
  channelId         String
  messageId         String @unique
  originalMessageId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
